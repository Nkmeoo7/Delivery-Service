<%
function statusBadge(status) {
  return `<span class="badge badge-${status}">${status}</span>`;
}
function fmtDate(ts) {
  if (!ts) return '—';
  return new Date(ts).toLocaleString();
}
function relTime(ts) {
  if (!ts) return '—';
  const diff = Date.now() - ts;
  if (diff < 60000) return `${Math.round(diff/1000)}s ago`;
  if (diff < 3600000) return `${Math.round(diff/60000)}m ago`;
  return `${Math.round(diff/3600000)}h ago`;
}

const totalActive = subscriptions.filter(s => s.is_active).length;
const totalDelivered = subscriptions.reduce((a, s) => a + (s.delivered_count || 0), 0);
const totalAbandoned = subscriptions.reduce((a, s) => a + (s.abandoned_count || 0), 0);
const totalPending = subscriptions.reduce((a, s) => a + (s.pending_count || 0), 0);
%>
<%- include('layout', { title: 'Subscriptions', body: `

<div class="page-header">
  <h1>Subscriptions</h1>
  <p>Registered webhook endpoints and their delivery statistics</p>
</div>

${error ? `<div class="alert alert-danger">❌ ${error}</div>` : ''}
${success ? `<div class="alert alert-success">✅ ${success}</div>` : ''}

<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">
    <h2>Register New Subscription</h2>
  </div>
  <div class="card-body" style="padding: 20px;">
    <form action="/dashboard/subscriptions" method="POST" style="display: flex; flex-direction: column; gap: 16px;">
      <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px;">
        <div class="form-group" style="display: flex; flex-direction: column; gap: 6px;">
          <label style="font-size: 11px; text-transform: uppercase; color: var(--muted); font-weight: 600; letter-spacing: 0.5px;">Target URL <span style="color:var(--red)">*</span></label>
          <input type="url" name="target_url" required placeholder="https://example.com/webhook" style="background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; color: var(--text); font-size: 13px; outline: none;" />
        </div>
        <div class="form-group" style="display: flex; flex-direction: column; gap: 6px;">
          <label style="font-size: 11px; text-transform: uppercase; color: var(--muted); font-weight: 600; letter-spacing: 0.5px;">Event Filter</label>
          <input type="text" name="event_filter" placeholder="*" value="*" style="background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; color: var(--text); font-size: 13px; outline: none;" />
        </div>
        <div class="form-group" style="display: flex; flex-direction: column; gap: 6px;">
          <label style="font-size: 11px; text-transform: uppercase; color: var(--muted); font-weight: 600; letter-spacing: 0.5px;">Signing Secret</label>
          <input type="text" name="secret" placeholder="Optional" style="background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; color: var(--text); font-size: 13px; outline: none;" />
        </div>
      </div>
      <div>
        <button type="submit" class="btn btn-primary" style="padding: 10px 20px; font-size: 13px;">Create Subscription</button>
      </div>
    </form>
  </div>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="label">Active Subscriptions</div>
    <div class="value blue">${totalActive}</div>
  </div>
  <div class="stat-card">
    <div class="label">Total Delivered</div>
    <div class="value green">${totalDelivered}</div>
  </div>
  <div class="stat-card">
    <div class="label">In Queue</div>
    <div class="value yellow">${totalPending}</div>
  </div>
  <div class="stat-card">
    <div class="label">Abandoned</div>
    <div class="value red">${totalAbandoned}</div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2>All Subscriptions (${subscriptions.length})</h2>
  </div>
  <div class="card-body">
    ${subscriptions.length === 0 ? `
      <div class="empty-state">
        <div class="icon">📭</div>
        <p>No subscriptions yet.</p>
        <p style="margin-top:8px">POST to <code>/api/subscriptions</code> to register one.</p>
      </div>
    ` : `
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Target URL</th>
          <th>Filter</th>
          <th>Delivered</th>
          <th>Pending</th>
          <th>Abandoned</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        ${subscriptions.map(s => `
          <tr>
            <td>${statusBadge(s.is_active ? 'active' : 'inactive')}</td>
            <td class="td-url" title="${s.target_url}">
              <a href="/dashboard/subscriptions/${s.id}">${s.target_url}</a>
            </td>
            <td><code>${s.event_filter}</code></td>
            <td style="color:var(--green)">${s.delivered_count || 0}</td>
            <td style="color:var(--yellow)">${s.pending_count || 0}</td>
            <td style="color:var(--red)">${s.abandoned_count || 0}</td>
            <td style="color:var(--muted);white-space:nowrap">${relTime(s.created_at)}</td>
            <td><a class="btn btn-ghost btn-sm" href="/dashboard/subscriptions/${s.id}">View →</a></td>
          </tr>
        `).join('')}
      </tbody>
    </table>
    `}
  </div>
</div>
` }) %>
