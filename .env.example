PORT=3000

# Path to the SQLite database file (created automatically on first run)
DB_PATH=./webhook.db

# Shared admin key — required on every API request as:  X-Admin-Key: <value>
ADMIN_KEY=change-me-in-production

# Maximum number of delivery attempts before an attempt is marked 'abandoned'
# After this, the attempt can still be manually retried from the dashboard.
MAX_ATTEMPTS=5

# How often the delivery worker polls for due attempts (milliseconds)
WORKER_INTERVAL_MS=2000

# Per-request HTTP timeout for outbound webhook deliveries (milliseconds)
# If the subscriber doesn't respond within this window the request is aborted
# and treated as a retryable network error.
DELIVERY_TIMEOUT_MS=5000

# Maximum number of concurrent in-flight deliveries per poll cycle
# Raising this increases throughput but also RAM and outbound connection usage.
WORKER_CONCURRENCY=50
