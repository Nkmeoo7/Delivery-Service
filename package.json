{
  "name": "assigment_webhook",
  "version": "1.0.0",
  "description": "A production-quality webhook delivery service built with Node.js + TypeScript. Accepts events, fans them out to matching subscriptions, retries failed deliveries with exponential backoff + jitter, and exposes an admin dashboard.",
